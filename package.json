{
  "name": "manc",
  "description": "MANC — Contemporary Art Publication",
  "version": "1.0.0",
  "author": {
    "name": "MANC",
    "email": "hello@manc.art"
  },
  "engines": {
    "ghost": ">=6.0.0"
  },
  "license": "MIT",
  "keywords": [
    "ghost",
    "theme",
    "ghost-theme"
  ],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xs": {"width": 100},
      "s":  {"width": 300},
      "m":  {"width": 600},
      "l":  {"width": 1000},
      "xl": {"width": 2000}
    },
    "card_assets": true,
    "custom": {
      "fonts": {
        "heading_font": {
          "type": "select",
          "options": ["Playfair Display", "Georgia", "Times New Roman"],
          "default": "Playfair Display"
        },
        "body_font": {
          "type": "select",
          "options": ["Inter", "System"],
          "default": "Inter"
        }
      }
    }
  }
}
