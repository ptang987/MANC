<article class="post-card {{post_class}} {{#if featured}}post-card--featured{{/if}}">
    {{#if feature_image}}
    <a class="post-card__image-link" href="{{url}}" aria-hidden="true" tabindex="-1">
        <div class="post-card__image-wrapper">
            <img
                class="post-card__image"
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 600w,
                        {{img_url feature_image size="l"}} 1000w"
                sizes="(max-width: 600px) 100vw, (max-width: 1000px) 50vw, 33vw"
                src="{{img_url feature_image size="m"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                loading="lazy"
            >
        </div>
    </a>
    {{/if}}
    <div class="post-card__content">
        {{#if primary_tag}}
        <div class="post-card__tag">
            <a href="{{primary_tag.url}}">{{primary_tag.name}}</a>
        </div>
        {{/if}}
        <h2 class="post-card__title">
            <a href="{{url}}">{{title}}</a>
        </h2>
        {{#if custom_excerpt}}
        <p class="post-card__excerpt">{{custom_excerpt}}</p>
        {{else if excerpt}}
        <p class="post-card__excerpt">{{excerpt words="20"}}</p>
        {{/if}}
        <footer class="post-card__footer">
            <div class="post-card__author">
                {{#foreach authors limit="1"}}
                    {{#if profile_image}}
                    <img class="post-card__author-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}" width="24" height="24" loading="lazy">
                    {{/if}}
                    <span class="post-card__author-name">{{name}}</span>
                {{/foreach}}
            </div>
            <time class="post-card__date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
        </footer>
    </div>
</article>
