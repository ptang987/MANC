<!DOCTYPE html>
<html lang="{{@site.locale}}" class="no-js">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    {{ghost_head}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{asset "css/screen.css"}}">
    <script>
        // Dark mode: apply before paint to avoid flash
        (function() {
            var saved = localStorage.getItem('manc-dark-mode');
            var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (saved === 'dark' || (saved === null && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
            }
            document.documentElement.classList.remove('no-js');
        })();
    </script>
    {{#block "og"}}{{/block}}
</head>
<body class="{{body_class}}">

{{> header}}

<main class="site-main" id="main-content">
    {{#block "content"}}{{/block}}
</main>

{{> footer}}

<script>
    // Dark mode toggle
    (function() {
        var toggle = document.getElementById('dark-mode-toggle');
        if (!toggle) return;

        function applyMode(dark) {
            if (dark) {
                document.documentElement.classList.add('dark-mode');
                localStorage.setItem('manc-dark-mode', 'dark');
            } else {
                document.documentElement.classList.remove('dark-mode');
                localStorage.setItem('manc-dark-mode', 'light');
            }
        }

        toggle.addEventListener('click', function() {
            var isDark = document.documentElement.classList.contains('dark-mode');
            applyMode(!isDark);
        });
    })();
</script>

{{ghost_foot}}
</body>
</html>
