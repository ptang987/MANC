{{!< default}}

{{#block "content"}}
<article class="page-full {{page_class}}">
    <header class="page-full__header">
        <div class="page-full__header-inner">
            <h1 class="page-full__title">{{title}}</h1>
            {{#if custom_excerpt}}
            <p class="page-full__excerpt">{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </header>

    {{#if feature_image}}
    <figure class="page-full__hero">
        <img
            srcset="{{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w,
                    {{img_url feature_image size="xl"}} 2000w"
            sizes="100vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        >
        {{#if feature_image_caption}}
        <figcaption>{{feature_image_caption}}</figcaption>
        {{/if}}
    </figure>
    {{/if}}

    <div class="page-full__content gh-content">
        {{content}}
    </div>
</article>
{{/block}}
